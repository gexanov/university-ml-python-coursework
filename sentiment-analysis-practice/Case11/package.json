{
  "name": "react-sentiment-analyzer",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "axios": "^1.13.2",
    "chart.js": "^4.5.1",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:backend": "uvicorn app:app --reload --host 0.0.0.0 --port 8000",
    "start:frontend": "npm run start",
    "start:all": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
